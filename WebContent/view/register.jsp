<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="kr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>회원가입</h1>
    <div>
        <div>사업자번호</div>
        <input type="text" value="" placeholder="사업자번호 입력해주세요"> 사업자번호
    </div>
    <div>
        <div>상호명</div>
        <input type="text" value="" placeholder="상호명 입력해주세요"> 상호명
    </div>
    <div>
        <div>성명</div>
        <input type="text" value="" placeholder="성명 입력해주세요"> 성명
    </div>
    <div>
        <div>이메일</div>
        <input type="text" value="" placeholder="이메일 입력해주세요"> 이메일
    </div>
    <div>
        <div>휴대폰인증</div>
        <input type="text" value="" placeholder="휴대폰인증 입력해주세요"> 휴대폰인증
    </div>
    <div>
        <div>비밀번호</div>
        <input type="text" value="" placeholder="비밀번호 입력해주세요"> 비밀번호
    </div>
    <div>
        <div>비밀번호 확인</div>
        <input type="text" value="" placeholder="비밀번호 입력해주세요"> 비밀번호
    </div>
    <div>사업자 유형 선택</div>
    <input type="radio" name="" id="">간이과세자
    <input type="radio" name="" id="">일반과세자
    <div>
        <div>
            업태 종류
        </div>
        <select name="" id="" value="일반음식점">업태종류</select>
        <select name="" id="" value="한식">한식</select>
    </div>
    <div>소상공인 증명</div>
    <input type="file" name="" id="">소상공인 증명 서류 제출
    <select name="" id=""></select>


    <div>
        <div><input type="checkbox" name="" id="">소득 확인을 위한 개인정보 동의 약관 필수</div>
        <div><input type="checkbox" name="" id="">개인정보 수집 동의 필수</div>
        <div><input type="checkbox" name="" id="">마케팅 정보 메일, SMS 수신 동의</div>
    </div>
</body>

</html>